---
import BaseLayout from '../layouts/BaseLayout.astro';
import { theme } from '../config/theme';
import { fetchGoodreadsBooks, fetchLetterboxdFilms, fetchYouTubeVideos, ratingToStars } from '../utils/rss';

// Fetch data at build time
const GOODREADS_ID = '43383319';
const BOOK_REVIEW_CHANNEL = 'UCtTpv51SwEz7hGc11H9kbLA';

const currentlyReading = await fetchGoodreadsBooks(GOODREADS_ID, 'currently-reading', 3);
const recentBooks = await fetchGoodreadsBooks(GOODREADS_ID, 'read', 4);
const recentFilms = await fetchLetterboxdFilms('zarrsadus', 4);
const recentVideos = await fetchYouTubeVideos(BOOK_REVIEW_CHANNEL, 3);

function extractPoster(html: string): string {
  const match = html.match(/src="([^"]+)"/);
  return match ? match[1] : '';
}

function formatDate(dateStr: string): string {
  try {
    return new Date(dateStr).toLocaleDateString('en-US', {
      month: 'short', day: 'numeric', year: 'numeric',
    });
  } catch { return ''; }
}
---

<BaseLayout title="Zachary Long | Books, Films & Data" showNav={false}>
  <main>

    <!-- ===== HERO ===== -->
    <section class="cin-hero fade-in">
      <div class="cin-hero-overlay" aria-hidden="true"></div>
      <div class="cin-hero-content">
        <h1 class="cin-hero-title">{theme.landing.siteTitle}</h1>
        <p class="cin-hero-tagline">{theme.landing.tagline || theme.landing.subtitle}</p>
        <nav class="cin-hero-nav" aria-label="Quick navigation">
          <a href="/books" class="cin-hero-link">Books</a>
          <span class="cin-hero-dot" aria-hidden="true"></span>
          <a href="/films" class="cin-hero-link">Films</a>
          <span class="cin-hero-dot" aria-hidden="true"></span>
          <a href="/videos" class="cin-hero-link">Videos</a>
        </nav>
      </div>
      <span class="cin-hero-scroll" aria-hidden="true">scroll</span>
    </section>

    <!-- ===== LATEST ===== -->
    <section class="cin-section">
      <div class="container">
        <h2 class="cin-section-title">Latest</h2>
        <div class="cin-featured-grid cin-stagger">
          {recentVideos.slice(0, 3).map((video) => (
            <div class="feed-card">
              <a href={video.link} target="_blank" rel="noopener">
                <img
                  src={video.thumbnailUrl}
                  alt={video.title}
                  class="feed-card-img"
                  loading="lazy"
                  referrerpolicy="no-referrer"
                />
                <div class="feed-card-body">
                  <span class="cin-card-type">Video</span>
                  <div class="feed-card-title">{video.title}</div>
                  {video.publishedDate && (
                    <div class="feed-card-date">{formatDate(video.publishedDate)}</div>
                  )}
                </div>
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <div class="cin-section-divider" aria-hidden="true"></div>

    <!-- ===== BOOKS & FILMS SPLIT ===== -->
    <section class="cin-section">
      <div class="container">
        <div class="cin-split-grid">

          <!-- Books Column -->
          <div class="cin-split-col">
            <h2 class="cin-split-heading"><a href="/books">Books</a></h2>
            <p class="cin-split-desc">Science fiction, fantasy, and everything in between.</p>
            <div class="cin-split-cards cin-stagger">
              {recentBooks.slice(0, 3).map((book) => (
                <div class="cin-compact-card">
                  <a href={book.link} target="_blank" rel="noopener">
                    {book.imageUrl && (
                      <img
                        src={book.imageUrl}
                        alt={book.title}
                        loading="lazy"
                        referrerpolicy="no-referrer"
                      />
                    )}
                    <div class="cin-compact-card-body">
                      <div class="cin-compact-card-title">{book.title}</div>
                      <div class="cin-compact-card-meta">{book.author}</div>
                      {book.rating > 0 && (
                        <div class="feed-card-rating">{ratingToStars(book.rating)}</div>
                      )}
                    </div>
                  </a>
                </div>
              ))}
            </div>
            <a href="/books" class="cin-more-link">View all books &rarr;</a>
          </div>

          <!-- Films Column -->
          <div class="cin-split-col">
            <h2 class="cin-split-heading"><a href="/films">Films</a></h2>
            <p class="cin-split-desc">World cinema, genre favorites, and fresh watches.</p>
            <div class="cin-split-cards cin-stagger">
              {recentFilms.slice(0, 3).map((film) => {
                const poster = extractPoster(film.posterHtml);
                return (
                  <div class="cin-compact-card">
                    <a href={film.link} target="_blank" rel="noopener">
                      {poster && (
                        <img
                          src={poster}
                          alt={film.title}
                          loading="lazy"
                          referrerpolicy="no-referrer"
                        />
                      )}
                      <div class="cin-compact-card-body">
                        <div class="cin-compact-card-title">
                          {film.title}
                          {film.year && <span style="color: var(--ff-text-grey);"> ({film.year})</span>}
                        </div>
                        {film.rating > 0 && (
                          <div class="feed-card-rating">{ratingToStars(film.rating)}</div>
                        )}
                      </div>
                    </a>
                  </div>
                );
              })}
            </div>
            <a href="/films" class="cin-more-link">View all films &rarr;</a>
          </div>

        </div>
      </div>
    </section>

    <div class="cin-section-divider" aria-hidden="true"></div>

    <!-- ===== ABOUT ===== -->
    <section class="cin-section">
      <div class="container">
        <div class="cin-about-content">
          <div class="cin-about-photo">
            <img src="/images/zachary-long.jpeg" alt="Zachary Long" />
          </div>
          <div class="cin-about-text">
            <h2>About</h2>
            <Fragment set:html={theme.landing.introHtml} />
            <div class="cin-about-links">
              <a href="/resume">Resume</a>
              <a href="https://www.linkedin.com/in/zaclong/" target="_blank" rel="noopener">LinkedIn</a>
              <a href="https://github.com/zacharylong" target="_blank" rel="noopener">GitHub</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== CURRENTLY READING ===== -->
    {currentlyReading.length > 0 && (
      <section class="cin-section">
        <div class="container">
          <h2 class="cin-section-title">Currently Reading</h2>
          <div class="cin-currently-grid cin-stagger">
            {currentlyReading.map((book) => (
              <div class="cin-compact-card">
                <a href={book.link} target="_blank" rel="noopener">
                  {book.imageUrl && (
                    <img
                      src={book.imageUrl}
                      alt={book.title}
                      loading="lazy"
                      referrerpolicy="no-referrer"
                    />
                  )}
                  <div class="cin-compact-card-body">
                    <div class="cin-compact-card-title">{book.title}</div>
                    <div class="cin-compact-card-meta">{book.author}</div>
                  </div>
                </a>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- ===== FOOTER ===== -->
    <footer class="cin-footer">
      <div class="container">
        <div class="cin-footer-content">
          <nav class="cin-footer-nav" aria-label="Footer navigation">
            <a href="/books">Books</a>
            <a href="/films">Films</a>
            <a href="/videos">Videos</a>
            <a href="/resume">Resume</a>
          </nav>
          <div class="cin-footer-social">
            {theme.socialItems.items.map((item) => (
              <a href={item.href} target="_blank" rel="noopener">{item.label}</a>
            ))}
          </div>
          <p
            class="cin-footer-copy"
            title={theme.footer?.easterEggTitle || ''}
          >
            &copy; {theme.footer?.copyright || '2025 Zachary Long'}
          </p>
        </div>
      </div>
    </footer>

  </main>
</BaseLayout>
