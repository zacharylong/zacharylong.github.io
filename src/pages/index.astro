---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Zachary Long | Data Analyst • Creator • Explorer" showNav={false}>
  <main class="landing">

    <!-- Gradient horizon background (CSS-only, no image needed) -->
    <div class="world-map-bg" aria-hidden="true"></div>

    <!-- Floating crystal sparkles -->
    <div class="sparkle-field" aria-hidden="true">
      <div class="sparkle s1"></div>
      <div class="sparkle s2"></div>
      <div class="sparkle s3"></div>
      <div class="sparkle s4"></div>
      <div class="sparkle s5"></div>
      <div class="sparkle s6"></div>
    </div>

    <div class="landing-content">

      <!-- Terra pixel-art sprite (CSS only — fallback to PNG if available) -->
      <div class="terra-wrap fade-in">
        <div class="terra-pixel-sprite" aria-hidden="true"></div>
      </div>

      <div class="ff-divider" aria-hidden="true"></div>

      <!-- Intro dialog box -->
      <div class="ff-box intro-box fade-in fade-in-delay-1">
        <h1>Zachary Long</h1>
        <p class="intro-subtitle">Data Analyst &bull; Creator &bull; Explorer</p>
        <p class="intro-text">
          I help institutions make faster, better decisions
          with analytics that leaders actually use.
        </p>
        <p class="intro-text" style="margin-top: var(--sp-3);">
          I live at the intersection of creativity, technology,
          and business — driven by a passion for using data to
          enhance human experiences and tell stories.
        </p>
      </div>

      <div class="ff-divider" aria-hidden="true"></div>

      <!-- Navigation menu with pixel-art icons -->
      <nav class="world-nav fade-in fade-in-delay-2" aria-label="Site sections">
        <div class="ff-box">
          <ul class="ff-menu">
            <li>
              <a href="/resume" class="ff-menu-item">
                <!-- Sword icon -->
                <svg class="menu-icon" viewBox="0 0 16 16" width="16" height="16" aria-hidden="true">
                  <rect x="7" y="0" width="2" height="2" fill="#a0a0c0"/>
                  <rect x="7" y="2" width="2" height="2" fill="#c0c0e0"/>
                  <rect x="7" y="4" width="2" height="2" fill="#c0c0e0"/>
                  <rect x="7" y="6" width="2" height="2" fill="#a0a0c0"/>
                  <rect x="3" y="8" width="10" height="2" fill="#e8b830"/>
                  <rect x="5" y="8" width="6" height="2" fill="#f8d848"/>
                  <rect x="7" y="10" width="2" height="2" fill="#806030"/>
                  <rect x="7" y="12" width="2" height="2" fill="#705028"/>
                  <rect x="6" y="14" width="4" height="2" fill="#604020"/>
                </svg>
                <span class="ff-menu-label">Narshe</span>
                <span class="ff-menu-sub">Resume</span>
              </a>
            </li>
            <li>
              <a href="/library" class="ff-menu-item">
                <!-- Book icon -->
                <svg class="menu-icon" viewBox="0 0 16 16" width="16" height="16" aria-hidden="true">
                  <rect x="3" y="1" width="10" height="2" fill="#705028"/>
                  <rect x="2" y="3" width="1" height="10" fill="#806030"/>
                  <rect x="3" y="3" width="10" height="10" fill="#f0e8d0"/>
                  <rect x="13" y="3" width="1" height="10" fill="#604020"/>
                  <rect x="5" y="5" width="6" height="1" fill="#404060"/>
                  <rect x="5" y="7" width="5" height="1" fill="#404060"/>
                  <rect x="5" y="9" width="4" height="1" fill="#404060"/>
                  <rect x="3" y="13" width="10" height="2" fill="#705028"/>
                </svg>
                <span class="ff-menu-label">Opera House</span>
                <span class="ff-menu-sub">Library</span>
              </a>
            </li>
            <li>
              <a href="/theater" class="ff-menu-item">
                <!-- Film/star icon -->
                <svg class="menu-icon" viewBox="0 0 16 16" width="16" height="16" aria-hidden="true">
                  <rect x="7" y="0" width="2" height="2" fill="#f8f870"/>
                  <rect x="3" y="2" width="2" height="2" fill="#f8f870"/>
                  <rect x="11" y="2" width="2" height="2" fill="#f8f870"/>
                  <rect x="5" y="4" width="6" height="2" fill="#f8f870"/>
                  <rect x="3" y="6" width="10" height="2" fill="#f8d848"/>
                  <rect x="5" y="8" width="6" height="2" fill="#e8b830"/>
                  <rect x="4" y="10" width="3" height="2" fill="#f8d848"/>
                  <rect x="9" y="10" width="3" height="2" fill="#f8d848"/>
                  <rect x="2" y="12" width="3" height="2" fill="#e8b830"/>
                  <rect x="11" y="12" width="3" height="2" fill="#e8b830"/>
                </svg>
                <span class="ff-menu-label">Jidoor</span>
                <span class="ff-menu-sub">Theater</span>
              </a>
            </li>
            <li>
              <a href="/creations" class="ff-menu-item">
                <!-- Airship icon -->
                <svg class="menu-icon" viewBox="0 0 16 16" width="16" height="16" aria-hidden="true">
                  <rect x="6" y="1" width="4" height="2" fill="#a0a0c0"/>
                  <rect x="4" y="3" width="8" height="2" fill="#c0c0e0"/>
                  <rect x="3" y="5" width="10" height="2" fill="#8888b0"/>
                  <rect x="2" y="7" width="12" height="2" fill="#a0a0c0"/>
                  <rect x="1" y="9" width="14" height="2" fill="#7878a0"/>
                  <rect x="6" y="9" width="4" height="2" fill="#d04040"/>
                  <rect x="3" y="11" width="10" height="1" fill="#606088"/>
                  <rect x="0" y="11" width="3" height="2" fill="#c0c0e0"/>
                  <rect x="13" y="11" width="3" height="2" fill="#c0c0e0"/>
                  <rect x="5" y="12" width="6" height="2" fill="#f8d848"/>
                </svg>
                <span class="ff-menu-label">The Blackjack</span>
                <span class="ff-menu-sub">Creations</span>
              </a>
            </li>
          </ul>
        </div>
      </nav>

      <div class="ff-divider" aria-hidden="true"></div>

      <!-- Social links as FF6 "Items" inventory -->
      <div class="ff-box social-inventory fade-in fade-in-delay-3">
        <p class="inventory-title">Items</p>
        <ul class="ff-menu">
          <li>
            <a href="https://www.linkedin.com/in/zaclong/" class="ff-menu-item" target="_blank" rel="noopener">
              <!-- Chain link icon -->
              <svg class="item-icon" viewBox="0 0 16 16" width="16" height="16" aria-hidden="true">
                <rect x="4" y="2" width="4" height="2" fill="#58d8d8"/>
                <rect x="2" y="4" width="2" height="4" fill="#58d8d8"/>
                <rect x="4" y="6" width="4" height="2" fill="#58d8d8"/>
                <rect x="8" y="8" width="4" height="2" fill="#58d8d8"/>
                <rect x="12" y="6" width="2" height="4" fill="#58d8d8"/>
                <rect x="8" y="12" width="4" height="2" fill="#58d8d8"/>
              </svg>
              <span class="ff-menu-label">LinkedIn</span>
            </a>
          </li>
          <li>
            <a href="https://github.com/zacharylong" class="ff-menu-item" target="_blank" rel="noopener">
              <!-- Diamond/gem icon -->
              <svg class="item-icon" viewBox="0 0 16 16" width="16" height="16" aria-hidden="true">
                <rect x="6" y="2" width="4" height="2" fill="#b0b0c8"/>
                <rect x="4" y="4" width="8" height="2" fill="#c0c0e0"/>
                <rect x="2" y="6" width="12" height="2" fill="#a0a0c0"/>
                <rect x="4" y="8" width="8" height="2" fill="#8888b0"/>
                <rect x="6" y="10" width="4" height="2" fill="#7070a0"/>
                <rect x="7" y="12" width="2" height="2" fill="#606088"/>
              </svg>
              <span class="ff-menu-label">GitHub</span>
            </a>
          </li>
          <li>
            <a href="https://www.goodreads.com/zacharylong" class="ff-menu-item" target="_blank" rel="noopener">
              <!-- Small book icon -->
              <svg class="item-icon" viewBox="0 0 16 16" width="16" height="16" aria-hidden="true">
                <rect x="4" y="2" width="8" height="2" fill="#58d858"/>
                <rect x="3" y="4" width="1" height="8" fill="#408040"/>
                <rect x="4" y="4" width="8" height="8" fill="#d8f0d0"/>
                <rect x="12" y="4" width="1" height="8" fill="#306830"/>
                <rect x="4" y="12" width="8" height="2" fill="#58d858"/>
              </svg>
              <span class="ff-menu-label">Goodreads</span>
            </a>
          </li>
          <li>
            <a href="https://letterboxd.com/zarrsadus/diary/" class="ff-menu-item" target="_blank" rel="noopener">
              <!-- Film frame icon -->
              <svg class="item-icon" viewBox="0 0 16 16" width="16" height="16" aria-hidden="true">
                <rect x="1" y="3" width="14" height="10" fill="#404060"/>
                <rect x="3" y="5" width="10" height="6" fill="#808098"/>
                <rect x="1" y="3" width="2" height="2" fill="#f8f870"/>
                <rect x="1" y="11" width="2" height="2" fill="#f8f870"/>
                <rect x="13" y="3" width="2" height="2" fill="#f8f870"/>
                <rect x="13" y="11" width="2" height="2" fill="#f8f870"/>
              </svg>
              <span class="ff-menu-label">Letterboxd</span>
            </a>
          </li>
          <li>
            <a href="https://www.strava.com/athletes/59082456" class="ff-menu-item" target="_blank" rel="noopener">
              <!-- Mountain/chocobo feather icon -->
              <svg class="item-icon" viewBox="0 0 16 16" width="16" height="16" aria-hidden="true">
                <rect x="7" y="2" width="2" height="2" fill="#f04848"/>
                <rect x="6" y="4" width="4" height="2" fill="#f04848"/>
                <rect x="5" y="6" width="6" height="2" fill="#f04848"/>
                <rect x="4" y="8" width="8" height="2" fill="#d03838"/>
                <rect x="3" y="10" width="10" height="2" fill="#c03030"/>
                <rect x="2" y="12" width="12" height="2" fill="#a02828"/>
              </svg>
              <span class="ff-menu-label">Strava</span>
            </a>
          </li>
        </ul>
      </div>

      <!-- Blinking prompt -->
      <p class="press-start fade-in fade-in-delay-4">— Select a destination —</p>
    </div>
  </main>
</BaseLayout>
