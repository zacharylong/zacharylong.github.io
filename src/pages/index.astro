---
import BaseLayout from '../layouts/BaseLayout.astro';
import { theme } from '../config/theme';
import { fetchGoodreadsBooks, fetchLetterboxdFilms, fetchYouTubeVideos, ratingToStars } from '../utils/rss';
import resumeData from '../data/resume.json';

// Fetch data at build time
const GOODREADS_ID = '43383319';
const PODCAST_CHANNEL = 'UCMtZjTRg5zKLJLDA1Cx8xGQ';
const BOOK_REVIEW_CHANNEL = 'UCtTpv51SwEz7hGc11H9kbLA';
const FILM_REVIEW_CHANNEL = 'UChJ39K5hJI7ARTTeB-KGOWQ';

const currentlyReading = await fetchGoodreadsBooks(GOODREADS_ID, 'currently-reading', 3);
const recentFilms = await fetchLetterboxdFilms('zarrsadus', 3);
const allPodcastVideos = await fetchYouTubeVideos(PODCAST_CHANNEL, 15);
const bookReviewVideos = await fetchYouTubeVideos(BOOK_REVIEW_CHANNEL, 3);
const filmReviewVideos = await fetchYouTubeVideos(FILM_REVIEW_CHANNEL, 3);

// Filter out YouTube Shorts
const podcastEpisodes = allPodcastVideos.filter((v) =>
  !v.title.toLowerCase().includes('#short') &&
  !v.title.toLowerCase().includes('#shorts')
).slice(0, 3);

function extractPoster(html: string): string {
  const match = html.match(/src="([^"]+)"/);
  return match ? match[1] : '';
}

function formatDate(dateStr: string): string {
  try {
    return new Date(dateStr).toLocaleDateString('en-US', {
      month: 'short', day: 'numeric', year: 'numeric',
    });
  } catch { return ''; }
}

function truncateTitle(title: string, maxLen: number = 60): string {
  if (!title || title.length <= maxLen) return title || '';
  return title.slice(0, maxLen).replace(/\s+\S*$/, '') + '\u2026';
}

// Live signals for portal cards
const nowReading = currentlyReading[0];
const latestFilm = recentFilms[0];
const latestPodcast = podcastEpisodes[0];
const latestBookReview = bookReviewVideos[0];
const latestFilmReview = filmReviewVideos[0];

const { landing } = theme;
---

<BaseLayout title="Zachary Long | Data, Books & Films" showNav={false}>
  <main>

    <!-- ===== ZONE A: Identity Deck ===== -->
    <section class="ath-identity" aria-label="Introduction">
      <div class="ath-identity-inner">

        <!-- Left Column -->
        <div class="ath-identity-left">
          <h1>{landing.siteTitle}</h1>
          <div class="ath-subtitle" set:html={landing.subtitle} />
          <p class="ath-positioning">{landing.positioningStatement}</p>
          <div class="ath-ctas">
            {landing.ctaPrimary && (
              <a href={landing.ctaPrimary.href} class="ath-cta ath-cta--primary">{landing.ctaPrimary.label}</a>
            )}
            {landing.ctaSecondary && (
              <a href={landing.ctaSecondary.href} class="ath-cta ath-cta--secondary">{landing.ctaSecondary.label}</a>
            )}
            {landing.ctaTertiary && (
              <a href={landing.ctaTertiary.href} class="ath-cta ath-cta--tertiary">{landing.ctaTertiary.label} &rarr;</a>
            )}
          </div>
        </div>

        <!-- Right Column -->
        <div class="ath-identity-right">
          <img
            src="/images/zachary-long.jpeg"
            alt="Zachary Long — Technical Business Analyst and content creator"
            class="ath-portrait"
            width="120"
            height="120"
          />

          <div class="ath-console">
            <div class="ath-console-title">Currently</div>
            {nowReading && (
              <div class="ath-console-item">
                <span class="ath-console-label">Reading</span>
                <span class="ath-console-value">
                  <a href={nowReading.link} target="_blank" rel="noopener">{truncateTitle(nowReading.title, 40)}</a>
                </span>
              </div>
            )}
            {latestFilm && (
              <div class="ath-console-item">
                <span class="ath-console-label">Watched</span>
                <span class="ath-console-value">
                  <a href={latestFilm.link} target="_blank" rel="noopener">
                    {latestFilm.title}{latestFilm.year ? ` (${latestFilm.year})` : ''}
                  </a>
                </span>
              </div>
            )}
          </div>

          {landing.credibilityLine && (
            <div class="ath-credibility">{landing.credibilityLine}</div>
          )}
        </div>

      </div>
    </section>

    <!-- ===== ZONE B: The Four Wings ===== -->
    {landing.portalCards && (
      <section class="ath-wings ath-reveal" aria-label="Explore">
        <div class="ath-wings-grid">
          {landing.portalCards.map((card) => (
            <a href={card.href} class="ath-wing-card">
              <div class="ath-wing-title">{card.title}</div>
              <div class="ath-wing-desc">{card.description}</div>
              <span class="ath-wing-arrow" aria-hidden="true">&rarr;</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- ===== ZONE C: Live Console Band ===== -->
    <section class="ath-console-band ath-reveal">
      <div class="ath-console-band-inner">
        <div class="ath-console-slot">
          <span class="ath-console-slot-label">Now Reading</span>
          {nowReading ? (
            <span class="ath-console-slot-value">
              <a href={nowReading.link} target="_blank" rel="noopener">{nowReading.title}</a>
            </span>
          ) : (
            <span class="ath-console-slot-value" style="color: var(--ff-text-grey);">Between books</span>
          )}
          {nowReading?.author && <span class="ath-console-slot-meta">{nowReading.author}</span>}
        </div>

        <div class="ath-console-slot">
          <span class="ath-console-slot-label">Recently Watched</span>
          {latestFilm ? (
            <span class="ath-console-slot-value">
              <a href={latestFilm.link} target="_blank" rel="noopener">
                {latestFilm.title}{latestFilm.year ? ` (${latestFilm.year})` : ''}
              </a>
            </span>
          ) : (
            <span class="ath-console-slot-value" style="color: var(--ff-text-grey);">Nothing recent</span>
          )}
          {latestFilm && latestFilm.rating > 0 && (
            <span class="ath-console-slot-meta">{ratingToStars(latestFilm.rating)}</span>
          )}
        </div>

        <div class="ath-console-slot">
          <span class="ath-console-slot-label">Latest Transmission</span>
          {latestPodcast ? (
            <span class="ath-console-slot-value">
              <a href={latestPodcast.link} target="_blank" rel="noopener">{truncateTitle(latestPodcast.title, 50)}</a>
            </span>
          ) : (
            <span class="ath-console-slot-value" style="color: var(--ff-text-grey);">Coming soon</span>
          )}
          {latestPodcast?.publishedDate && (
            <span class="ath-console-slot-meta">{formatDate(latestPodcast.publishedDate)}</span>
          )}
        </div>
      </div>
    </section>

    <!-- ===== ZONE D: Lore + Logic ===== -->
    {landing.loreLogicHtml && (
      <section class="ath-lore ath-reveal">
        <h2>{landing.loreLogicHeading || 'Lore + Logic'}</h2>
        <Fragment set:html={landing.loreLogicHtml} />
        <div class="ath-lore-divider" aria-hidden="true"></div>
      </section>
    )}

    <!-- ===== ZONE E: Featured Work ===== -->
    <section class="ath-featured ath-reveal">
      <div class="ath-featured-heading">Latest</div>
      <div class="ath-featured-grid">

        {/* Large card: Latest podcast episode */}
        {latestPodcast && (
          <div class="ath-featured-card ath-featured-card--large">
            <a href={latestPodcast.link} target="_blank" rel="noopener">
              <img
                src={latestPodcast.thumbnailUrl}
                alt={latestPodcast.title}
                loading="lazy"
                referrerpolicy="no-referrer"
              />
              <div class="ath-featured-card-body">
                <span class="ath-featured-card-type">Podcast</span>
                <div class="ath-featured-card-title">{latestPodcast.title}</div>
                {latestPodcast.publishedDate && (
                  <span class="ath-featured-card-meta">{formatDate(latestPodcast.publishedDate)}</span>
                )}
              </div>
            </a>
          </div>
        )}

        {/* Small cards row */}
        <div class="ath-featured-small-row">
          {/* Book review */}
          {latestBookReview && (
            <div class="ath-featured-card ath-featured-card--small">
              <a href={latestBookReview.link} target="_blank" rel="noopener">
                <img
                  src={latestBookReview.thumbnailUrl}
                  alt={latestBookReview.title}
                  loading="lazy"
                  referrerpolicy="no-referrer"
                />
                <div class="ath-featured-card-body">
                  <span class="ath-featured-card-type">Book Review</span>
                  <div class="ath-featured-card-title">{latestBookReview.title}</div>
                </div>
              </a>
            </div>
          )}

          {/* Film review */}
          {latestFilmReview && (
            <div class="ath-featured-card ath-featured-card--small">
              <a href={latestFilmReview.link} target="_blank" rel="noopener">
                <img
                  src={latestFilmReview.thumbnailUrl}
                  alt={latestFilmReview.title}
                  loading="lazy"
                  referrerpolicy="no-referrer"
                />
                <div class="ath-featured-card-body">
                  <span class="ath-featured-card-type">Film Review</span>
                  <div class="ath-featured-card-title">{latestFilmReview.title}</div>
                </div>
              </a>
            </div>
          )}
        </div>

      </div>
    </section>

    <!-- ===== ZONE F: Footer ===== -->
    <footer class="ath-footer">
      <div class="ath-footer-inner">

        <!-- Primary nav -->
        <nav class="ath-footer-nav" aria-label="Footer navigation">
          {theme.menu.map((item) => (
            <a href={item.href}>{item.label}</a>
          ))}
        </nav>

        <!-- External links -->
        <div class="ath-footer-external">
          {theme.socialItems.items.map((item) => (
            <a href={item.href} target="_blank" rel="noopener">{item.label}</a>
          ))}
        </div>

        <!-- Statement -->
        <p class="ath-footer-statement">
          Systems thinker, storyteller, and lifelong learner. This site is where data meets narrative.
        </p>

        <!-- Copyright -->
        <p
          class="ath-footer-copy"
          title={theme.footer?.easterEggTitle || ''}
        >
          &copy; {theme.footer?.copyright || '2026 Zachary Long'}
        </p>

        <!-- Hidden easter egg -->
        <span
          aria-hidden="true"
          style="font-family: var(--ff-pixel); font-size: 5px; color: var(--ff-border-lo); opacity: 0.12; pointer-events: none; letter-spacing: 2px; margin-top: var(--sp-4);"
        >ARRAKEEN ARCHIVE // ACCESS GRANTED</span>

      </div>
    </footer>

  </main>

  <!-- Scroll reveal observer -->
  <script is:inline>
    (function() {
      var els = document.querySelectorAll('.ath-reveal');
      if (!els.length) return;
      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1 });
      els.forEach(function(el) { observer.observe(el); });
    })();
  </script>
</BaseLayout>
