---
import BaseLayout from '../layouts/BaseLayout.astro';
import { theme } from '../config/theme';
---

<BaseLayout title="Zachary Long | Data Analyst • Creator • Explorer" showNav={false}>
  <main class="landing">

    <!-- World map background -->
    <div class="world-map-bg" aria-hidden="true"></div>

    <!-- Floating particles -->
    <div class="sparkle-field" aria-hidden="true">
      <div class="sparkle s1"></div>
      <div class="sparkle s2"></div>
      <div class="sparkle s3"></div>
      <div class="sparkle s4"></div>
      <div class="sparkle s5"></div>
      <div class="sparkle s6"></div>
    </div>

    <div class="landing-content">

      <!-- Hero sprites -->
      <div class="hero-sprites fade-in">
        {theme.landing.heroSprites.map((sprite) => (
          <img
            src={sprite.src}
            alt={sprite.alt}
            class={sprite.className}
          />
        ))}
      </div>

      <div class="ff-divider" aria-hidden="true"></div>

      <!-- Intro dialog box -->
      <div class="ff-box intro-box fade-in fade-in-delay-1">
        <h1>{theme.landing.siteTitle}</h1>
        <p class="intro-subtitle" set:html={theme.landing.subtitle} />
        <Fragment set:html={theme.landing.introHtml} />
      </div>

      <div class="ff-divider" aria-hidden="true"></div>

      <!-- Navigation menu -->
      <nav class="world-nav fade-in fade-in-delay-2" aria-label="Site sections">
        <div class="ff-box">
          <ul class="ff-menu">
            {theme.menu.map((item) => (
              <li>
                <a href={item.href} class="ff-menu-item">
                  <img src={item.sprite} alt="" class="menu-sprite pixel" aria-hidden="true" />
                  <span class="ff-menu-text">
                    <span class="ff-menu-label">{item.label}</span>
                    <span class="ff-menu-sub">{item.sub}</span>
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </nav>

      <div class="ff-divider" aria-hidden="true"></div>

      <!-- Social links -->
      <div class="ff-box social-inventory fade-in fade-in-delay-3">
        <p class="inventory-title">{theme.socialItems.title}</p>
        <ul class="ff-menu">
          {theme.socialItems.items.map((item) => (
            <li>
              <a href={item.href} class="ff-menu-item" target="_blank" rel="noopener">
                <img src={item.icon} alt="" class="item-icon pixel" aria-hidden="true" />
                <span class="ff-menu-label">{item.label}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Blinking prompt -->
      <p class="press-start fade-in fade-in-delay-4">{theme.prompt}</p>
    </div>
  </main>
</BaseLayout>
