---
import BaseLayout from '../layouts/BaseLayout.astro';
import { theme } from '../config/theme';
import { fetchGoodreadsBooks, fetchLetterboxdFilms, fetchYouTubeVideos, ratingToStars } from '../utils/rss';
import resumeData from '../data/resume.json';

// Fetch data at build time
const GOODREADS_ID = '43383319';
const PODCAST_CHANNEL = 'UCMtZjTRg5zKLJLDA1Cx8xGQ';
const BOOK_REVIEW_CHANNEL = 'UCtTpv51SwEz7hGc11H9kbLA';
const FILM_REVIEW_CHANNEL = 'UChJ39K5hJI7ARTTeB-KGOWQ';

const currentlyReading = await fetchGoodreadsBooks(GOODREADS_ID, 'currently-reading', 3);
const recentFilms = await fetchLetterboxdFilms('zarrsadus', 3);
const allPodcastVideos = await fetchYouTubeVideos(PODCAST_CHANNEL, 15);
const bookReviewVideos = await fetchYouTubeVideos(BOOK_REVIEW_CHANNEL, 3);
const filmReviewVideos = await fetchYouTubeVideos(FILM_REVIEW_CHANNEL, 3);

// Filter out YouTube Shorts (typically have #shorts in title or very short descriptions)
const podcastEpisodes = allPodcastVideos.filter((v) =>
  !v.title.toLowerCase().includes('#short') &&
  !v.title.toLowerCase().includes('#shorts')
).slice(0, 3);

function extractPoster(html: string): string {
  const match = html.match(/src="([^"]+)"/);
  return match ? match[1] : '';
}

function formatDate(dateStr: string): string {
  try {
    return new Date(dateStr).toLocaleDateString('en-US', {
      month: 'short', day: 'numeric', year: 'numeric',
    });
  } catch { return ''; }
}

function truncateDesc(desc: string, maxLen: number = 140): string {
  if (!desc || desc.length <= maxLen) return desc || '';
  return desc.slice(0, maxLen).replace(/\s+\S*$/, '') + '...';
}

---

<BaseLayout title="Zachary Long | Data, Books & Films" showNav={false}>
  <main>

    <!-- ===== HERO ===== -->
    <section class="cin-hero fade-in">
      <div class="cin-hero-overlay" aria-hidden="true"></div>
      <div class="cin-hero-content">
        <h1 class="cin-hero-title">{theme.landing.siteTitle}</h1>
        <p class="cin-hero-tagline">{theme.landing.tagline || theme.landing.subtitle}</p>
        <nav class="cin-hero-nav" aria-label="Quick navigation">
          <a href="/resume" class="cin-hero-link">Resume</a>
          <span class="cin-hero-dot" aria-hidden="true"></span>
          <a href="#podcast" class="cin-hero-link">Podcast</a>
          <span class="cin-hero-dot" aria-hidden="true"></span>
          <a href="/books" class="cin-hero-link">Books</a>
          <span class="cin-hero-dot" aria-hidden="true"></span>
          <a href="/films" class="cin-hero-link">Films</a>
        </nav>
      </div>
      <span class="cin-hero-scroll" aria-hidden="true">scroll</span>
    </section>

    <!-- ===== PROFESSIONAL SPOTLIGHT ===== -->
    <section class="cin-section" id="podcast">
      <div class="container">
        <div class="cin-pro-spotlight">

          <!-- Left: Photo + Title + CTAs -->
          <div class="cin-pro-info">
            <div class="cin-pro-photo">
              <img src="/images/zachary-long.jpeg" alt="Zachary Long" />
            </div>
            <div class="cin-pro-name">{resumeData.name}</div>
            <div class="cin-pro-title">{resumeData.title}</div>
            <p class="cin-pro-tagline">{resumeData.tagline}</p>
            <div class="cin-pro-ctas">
              <a href="/resume" class="cin-cta-btn cin-cta-btn--primary">View Resume</a>
              <a href={resumeData.links.linkedin} target="_blank" rel="noopener" class="cin-cta-btn">LinkedIn</a>
            </div>
          </div>

          <!-- Right: Latest Podcast Episodes -->
          <div class="cin-pro-featured">
            <div class="cin-pro-featured-label">Everyday Data with PnZ</div>
            {podcastEpisodes.length > 0 ? (
              <div class="cin-pro-podcast-grid">
                {podcastEpisodes.map((ep) => (
                  <div class="cin-pro-podcast-card">
                    <a href={ep.link} target="_blank" rel="noopener">
                      <img
                        src={ep.thumbnailUrl}
                        alt={ep.title}
                        loading="lazy"
                        referrerpolicy="no-referrer"
                      />
                      <div class="cin-pro-podcast-body">
                        <div class="feed-card-title">{ep.title}</div>
                        {ep.publishedDate && (
                          <div class="feed-card-date">{formatDate(ep.publishedDate)}</div>
                        )}
                      </div>
                    </a>
                  </div>
                ))}
              </div>
            ) : (
              <div class="ff-box" style="text-align: center; padding: var(--sp-8);">
                <p style="color: var(--ff-text-dim);">Everyday Data with PnZ</p>
              </div>
            )}
            <div style="text-align: center; margin-top: var(--sp-4);">
              <a
                href="https://www.youtube.com/@EverydayDataWithPnZ"
                target="_blank"
                rel="noopener"
                class="cin-more-link"
              >
                All episodes &rarr;
              </a>
            </div>
          </div>

        </div>
      </div>
    </section>

    <div class="cin-section-divider" aria-hidden="true"></div>

    <!-- ===== CURRENTLY READING & RECENTLY WATCHED ===== -->
    <section class="cin-section">
      <div class="container">
        <div class="cin-split-grid">

          <!-- Currently Reading -->
          <div class="cin-split-col">
            <h2 class="cin-split-heading"><a href="/books">Currently Reading</a></h2>
            <p class="cin-split-desc">Science fiction, fantasy, and everything in between.</p>
            <div class="cin-split-cards cin-stagger">
              {currentlyReading.length > 0 ? (
                currentlyReading.map((book) => (
                  <div class="cin-compact-card">
                    <a href={book.link} target="_blank" rel="noopener">
                      {book.imageUrl && (
                        <img
                          src={book.imageUrl}
                          alt={book.title}
                          loading="lazy"
                          referrerpolicy="no-referrer"
                        />
                      )}
                      <div class="cin-compact-card-body">
                        <div class="cin-compact-card-title">{book.title}</div>
                        <div class="cin-compact-card-meta">{book.author}</div>
                      </div>
                    </a>
                  </div>
                ))
              ) : (
                <p style="color: var(--ff-text-dim); font-size: 14px;">Between books at the moment...</p>
              )}
            </div>
            <a href="/books" class="cin-more-link">View all books &rarr;</a>
          </div>

          <!-- Recently Watched -->
          <div class="cin-split-col">
            <h2 class="cin-split-heading"><a href="/films">Recently Watched</a></h2>
            <p class="cin-split-desc">World cinema, genre favorites, and fresh watches.</p>
            <div class="cin-split-cards cin-stagger">
              {recentFilms.slice(0, 3).map((film) => {
                const poster = extractPoster(film.posterHtml);
                return (
                  <div class="cin-compact-card">
                    <a href={film.link} target="_blank" rel="noopener">
                      {poster && (
                        <img
                          src={poster}
                          alt={film.title}
                          loading="lazy"
                          referrerpolicy="no-referrer"
                        />
                      )}
                      <div class="cin-compact-card-body">
                        <div class="cin-compact-card-title">
                          {film.title}
                          {film.year && <span style="color: var(--ff-text-grey);"> ({film.year})</span>}
                        </div>
                        {film.rating > 0 && (
                          <div class="feed-card-rating">{ratingToStars(film.rating)}</div>
                        )}
                      </div>
                    </a>
                  </div>
                );
              })}
            </div>
            <a href="/films" class="cin-more-link">View all films &rarr;</a>
          </div>

        </div>
      </div>
    </section>

    <div class="cin-section-divider" aria-hidden="true"></div>

    <!-- ===== REVIEWS & CONTENT ===== -->
    <section class="cin-section">
      <div class="container">
        <h2 class="cin-section-title">Reviews</h2>

        <!-- Sci-Fi & Fantasy Book Reviews -->
        <div class="cin-channel-group">
          <div class="cin-channel-header">
            <span class="cin-channel-name">Sci-Fi &amp; Fantasy Book Reviews</span>
            <a
              href="https://www.youtube.com/channel/UCtTpv51SwEz7hGc11H9kbLA"
              target="_blank"
              rel="noopener"
              class="cin-channel-link"
            >
              Watch on YouTube &rarr;
            </a>
          </div>
          {bookReviewVideos.length > 0 ? (
            <div class="cin-featured-grid cin-stagger">
              {bookReviewVideos.slice(0, 3).map((video) => (
                <div class="feed-card">
                  <a href={video.link} target="_blank" rel="noopener">
                    <img
                      src={video.thumbnailUrl}
                      alt={video.title}
                      class="feed-card-img"
                      loading="lazy"
                      referrerpolicy="no-referrer"
                    />
                    <div class="feed-card-body">
                      <div class="feed-card-title">{video.title}</div>
                      {video.publishedDate && (
                        <div class="feed-card-date">{formatDate(video.publishedDate)}</div>
                      )}
                    </div>
                  </a>
                </div>
              ))}
            </div>
          ) : (
            <div class="ff-box" style="text-align: center; padding: var(--sp-6);">
              <p style="color: var(--ff-text-dim);">New book reviews coming soon.</p>
            </div>
          )}
        </div>

        <!-- Zac On Films | Everything Film Club -->
        <div class="cin-channel-group">
          <div class="cin-channel-header">
            <span class="cin-channel-name">Zac On Films | Everything Film Club</span>
            <a
              href="https://www.youtube.com/channel/UChJ39K5hJI7ARTTeB-KGOWQ"
              target="_blank"
              rel="noopener"
              class="cin-channel-link"
            >
              Watch on YouTube &rarr;
            </a>
          </div>
          {filmReviewVideos.length > 0 ? (
            <div class="cin-featured-grid cin-stagger">
              {filmReviewVideos.slice(0, 3).map((video) => (
                <div class="feed-card">
                  <a href={video.link} target="_blank" rel="noopener">
                    <img
                      src={video.thumbnailUrl}
                      alt={video.title}
                      class="feed-card-img"
                      loading="lazy"
                      referrerpolicy="no-referrer"
                    />
                    <div class="feed-card-body">
                      <div class="feed-card-title">{video.title}</div>
                      {video.publishedDate && (
                        <div class="feed-card-date">{formatDate(video.publishedDate)}</div>
                      )}
                    </div>
                  </a>
                </div>
              ))}
            </div>
          ) : (
            <div class="ff-box" style="text-align: center; padding: var(--sp-6);">
              <p style="color: var(--ff-text-dim);">New film reviews coming soon.</p>
            </div>
          )}
        </div>

        <!-- Letterboxd -->
        <div style="text-align: center; margin-top: var(--sp-4);">
          <a
            href="https://letterboxd.com/zarrsadus/diary/"
            target="_blank"
            rel="noopener"
            class="cin-more-link"
          >
            Full diary on Letterboxd &rarr;
          </a>
        </div>
      </div>
    </section>

    <div class="cin-section-divider" aria-hidden="true"></div>

    <!-- ===== ABOUT ===== -->
    <section class="cin-section">
      <div class="container">
        <div style="max-width: 700px; margin: 0 auto; text-align: center;">
          <h2 style="margin-bottom: var(--sp-4);">About</h2>
          <Fragment set:html={theme.landing.introHtml} />
          <div class="cin-footer-social" style="margin-top: var(--sp-6); margin-bottom: 0;">
            {theme.socialItems.items.map((item) => (
              <a href={item.href} target="_blank" rel="noopener">{item.label}</a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ===== FOOTER ===== -->
    <footer class="cin-footer">
      <div class="container">
        <div class="cin-footer-content">
          <nav class="cin-footer-nav" aria-label="Footer navigation">
            <a href="/resume">Resume</a>
            <a href="/books">Books</a>
            <a href="/films">Films</a>
            <a href="/videos">Videos</a>
          </nav>
          <div class="cin-footer-social">
            {theme.socialItems.items.map((item) => (
              <a href={item.href} target="_blank" rel="noopener">{item.label}</a>
            ))}
          </div>
          <p
            class="cin-footer-copy"
            title={theme.footer?.easterEggTitle || ''}
          >
            &copy; {theme.footer?.copyright || '2025 Zachary Long'}
          </p>
        </div>
      </div>
    </footer>

  </main>
</BaseLayout>
