---
import BaseLayout from '../layouts/BaseLayout.astro';
import { theme } from '../config/theme';

const notFound = theme.pages.notFound;
---

<BaseLayout title={notFound.title} showNav={false}>
  <main class="page-404">

    <div class="zozo-title fade-in">{notFound.heading}</div>
    <div class="zozo-subtitle fade-in fade-in-delay-1">
      {notFound.subtitle}
    </div>

    <div class="ff-box zozo-dialog fade-in fade-in-delay-2">
      <p set:html={notFound.flavorHtml} />
      <hr />
      <p style="color: var(--ff-text-dim);" set:html={notFound.explanationHtml} />
    </div>

    <nav class="fade-in fade-in-delay-3">
      <div class="ff-box" style="min-width: 260px;">
        <ul class="ff-menu">
          {notFound.navLinks.map((link) => (
            <li>
              <a href={link.href} class="ff-menu-item">
                <span class="ff-menu-label">{link.label}</span>
                {link.sub && <span class="ff-menu-sub">{link.sub}</span>}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </nav>

    <!-- Easter egg: hidden retro reference -->
    <span
      class="visually-hidden"
      aria-hidden="true"
      style="position: absolute; bottom: 8px; right: 8px; font-family: var(--ff-pixel); font-size: 6px; color: var(--ff-border-lo); opacity: 0.15; pointer-events: none; clip: auto; width: auto; height: auto; overflow: visible; white-space: nowrap;"
    >Zozo was here</span>

  </main>
</BaseLayout>
